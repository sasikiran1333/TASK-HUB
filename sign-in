<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>TASKHUB SIGNUP</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="style.css">

</head>

<body class="sign-in">

<form class="container">

<h1>TASKHUB</h1>

<div class="name-box">
<input type="text" name="firstname" placeholder="First Name" required>
<input type="text" name="lastname" placeholder="Last Name" required><br><br>
</div>

<input type="tel" name="phone" placeholder="+91 Phone Number"
pattern="[0-9]{10}" required><br>

<label>Gender:</label><br><br>

<span><input type="radio" name="gender" required> Male</span>
<span><input type="radio" name="gender" required> Female</span>
<span><input type="radio" name="gender" required> Other</span><br>

<h3>Select Date of Birth:</h3>
<input type="date" id="dob" placeholder="DD-MM-YYYY" required><br>

<a href="sign-in2.html"
button>NEXT</button></a>

</form>

</body>
</html>
